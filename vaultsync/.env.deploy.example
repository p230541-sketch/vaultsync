# Free single-VM deployment config. Copy to `.env` on the VM (next to
# docker-compose.yml) and fill in. docker compose reads this automatically.

# Public hostname that resolves to the VM (e.g. a free DuckDNS subdomain).
DOMAIN=your-name.duckdns.org

# Enables production hardening (fail-closed config + Secure cookies).
NODE_ENV=production

# REQUIRED in production — generate strong unique values:
#   JWT_SECRET:        openssl rand -hex 32
#   POSTGRES_PASSWORD: openssl rand -base64 24
JWT_SECRET=__CHANGE_ME__
POSTGRES_PASSWORD=__CHANGE_ME__

# Internal container Postgres has no TLS — keep this as 'disable'.
PG_SSLMODE=disable
